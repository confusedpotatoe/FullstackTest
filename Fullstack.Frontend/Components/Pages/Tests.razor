@page "/test-status"
@rendermode InteractiveServer

<div class="container mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h1>🧪 Testöversikt</h1>
        <span class="badge bg-success fs-5">Backend: Godkänd</span>
    </div>

    @* Information om GitHub Actions (Viktigt för VG) *@
    <div class="alert alert-info shadow-sm mb-4">
        <strong>GitHub Actions:</strong> Varje commit körs automatiskt genom en CI/CD-pipeline som validerar alla @testCount tester.
        <a href="https://github.com/confusedpotatoe/FullstackTest/actions" target="_blank" class="alert-link">Se körningar här ⮕</a>
    </div>

    <div class="row">
        <div class="col-md-8">
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-dark text-white">
                    <h5 class="mb-0">Genomförda Enhetstester (xUnit)</h5>
                </div>
                <div class="card-body">
                    <table class="table table-hover">
                        <thead>
                            <tr>
                                <th>Testfall (AAA-mönster)</th>
                                <th>Område</th>
                                <th>Status</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var test in testList)
                            {
                                <tr>
                                    <td><code>@test.Name</code></td>
                                    <td>@test.Category</td>
                                    <td><span class="text-success">✔ Pass</span></td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

        <div class="col-md-4">
            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">Testarkitektur</h5>
                </div>
                <div class="card-body">
                    <ul class="list-group list-group-flush">
                        <li class="list-group-item"><strong>Ramverk:</strong> xUnit [3]</li>
                        <li class="list-group-item"><strong>Mocking:</strong> NSubstitute [2]</li>
                        <li class="list-group-item"><strong>Princip:</strong> Arrange-Act-Assert [2]</li>
                        <li class="list-group-item"><strong>Projekt:</strong> FullstackTest.Tests [4]</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>
</div>

@code {
    private int testCount = 7;

    // Lista baserad på de tester du lagt till i din repository [1, 4]
    private List<TestInfo> testList = new()
    {
        new("GetAllProducts_ReturnsList", "ProductService"),
        new("GetProductById_ValidId_ReturnsProduct", "ProductService"),
        new("CreateProduct_ValidDto_ReturnsCreated", "ProductService"),
        new("DeleteProduct_ExistingId_ReturnsTrue", "ProductService"),
        new("GetAllCategories_ReturnsAll", "CategoryService"),
        new("CreateCategory_WithDescription_SavesData", "CategoryService"),
        new("GetCategoryById_NotFound_ReturnsNull", "CategoryService")
    };

    public record TestInfo(string Name, string Category);
}
