@page "/products"
@using FullstackTest.Application.DTOs
@inject HttpClient Http
@inject NavigationManager NavManager
@rendermode InteractiveServer

<PageTitle>Produkter</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Produkthantering</h1>
    <button class="btn btn-primary" @onclick='() => NavManager.NavigateTo("/add-product")'>
        ➕ Lägg till ny produkt
    </button>
</div>

@* Grundläggande felhantering: Visar felmeddelande om API:et inte svarar (Krav för G) *@
@if (!string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-danger" role="alert">
        @errorMessage
        <button class="btn btn-link p-0 ms-2" @onclick="LoadProducts">Försök igen</button>
    </div>
}

@if (products == null && string.IsNullOrEmpty(errorMessage))
{
    <div class="alert alert-info">Laddar produkter från API...</div>
}
else if (products?.Count == 0)
{
    <p>Inga produkter hittades i databasen.</p>
}
else if (products != null)
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Namn</th>
                <th>Pris</th>
                <th>Kategori</th>
                <th>Åtgärder</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in products)
            {
                <tr>
                    <td>@product.Name</td>
                    <td>@product.Price.ToString("C")</td>
                    <td>@product.CategoryName</td>
                    <td>
                        <div class="btn-group">
                            @* Kopplar till din nyskapade redigeringssida *@
                            <button class="btn btn-outline-dark btn-sm" @onclick="() => EditProduct(product.Id)">Redigera</button>
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteProduct(product.Id)">Ta bort</button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<ProductDto>? products;
    private string? errorMessage;

    protected override async Task OnInitializedAsync()
    {
        await LoadProducts();
    }

    private async Task LoadProducts()
    {
        errorMessage = null;
        try
        {
            // Sida för att visa data från API:t (Krav för G)
            products = await Http.GetFromJsonAsync<List<ProductDto>>("api/products");
        }
        catch (Exception)
        {
            // Fångar fel om t.ex. backend är nere (Krav för G)
            errorMessage = "Kunde inte hämta produkter. Kontrollera att API-servern körs.";
        }
    }

    // Funktion för att uppdatera data (Krav för G: Navigerar till din Edit-sida)
    private void EditProduct(int id) => NavManager.NavigateTo($"/edit-product/{id}");

    // Funktion för att ta bort data (Krav för G)
    private async Task DeleteProduct(int id)
    {
        try
        {
            var response = await Http.DeleteAsync($"api/products/{id}");
            if (response.IsSuccessStatusCode)
            {
                // Uppdaterar listan lokalt för omedelbar respons i UI:t
                products = products?.Where(p => p.Id != id).ToList();
            }
            else
            {
                errorMessage = "Gick inte att ta bort produkten. Servern svarade med ett fel.";
            }
        }
        catch (Exception)
        {
            errorMessage = "Ett fel uppstod vid försök att ta bort produkten.";
        }
    }
}