@page "/products"
@using FullstackTest.Application.DTOs
@inject HttpClient Http
@inject NavigationManager NavManager
@rendermode InteractiveServer

<PageTitle>Produkter</PageTitle>

<div class="d-flex justify-content-between align-items-center mb-4">
    <h1>Produkthantering</h1>
    <button class="btn btn-primary" @onclick='() => NavManager.NavigateTo("/add-product")'>
        ➕ Lägg till ny produkt
    </button>
</div>

@if (products == null)
{
    <div class="alert alert-info">Laddar produkter från API...</div>
}
else if (products.Count == 0)
{
    <p>Inga produkter hittades i databasen.</p>
}
else
{
    <table class="table table-striped">
        <thead>
            <tr>
                <th>Namn</th>
                <th>Pris</th>
                <th>Kategori</th>
                <th>Åtgärder</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var product in products)
            {
                <tr>
                    <td>@product.Name</td>
                    <td>@product.Price: -</td>
                    <td>@product.CategoryName</td>
                    <td>
                        <div class="btn-group">
                            <button class="btn btn-outline-dark btn-sm" @onclick="() => EditProduct(product.Id)">Redigera</button>
                            <button class="btn btn-outline-danger btn-sm" @onclick="() => DeleteProduct(product.Id)">Ta bort</button>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
}

@code {
    private List<ProductDto>? products;

    protected override async Task OnInitializedAsync()
    {
        try
        {

            products = await Http.GetFromJsonAsync<List<ProductDto>>("api/products");
        }
        catch (Exception ex)
        {
            Console.WriteLine($"Ett fel uppstod: {ex.Message}");
        }
    }

    private void CreateNewProduct() => Console.WriteLine("Navigera till Skapa-sida");
    private void EditProduct(int id) => Console.WriteLine($"Navigera till Redigera-sida för ID: {id}");

    private async Task DeleteProduct(int id)
    {
        // Enkel bekräftelse innan radering
        var response = await Http.DeleteAsync($"api/products/{id}");
        if (response.IsSuccessStatusCode)
        {
            // Uppdatera listan lokalt efter lyckad borttagning
            products = products?.Where(p => p.Id != id).ToList();
        }
    }
}